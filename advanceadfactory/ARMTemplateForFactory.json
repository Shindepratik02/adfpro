											}
										}
									],
									"outputs": [
										{
											"referenceName": "ds_filessink",
											"type": "DatasetReference",
											"parameters": {
												"container": "sink",
												"folder": {
													"value": "@replace(item().name,'.csv','')",
													"type": "Expression"
												},
												"file": {
													"value": "@item().name",
													"type": "Expression"
												}
											}
										}
									]
								}
							]
						}
					},
					{
						"name": "Validation1",
						"type": "Validation",
						"dependsOn": [],
