{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "advanceadfactory"
		},
		"ls_adls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls'"
		},
		"ls_db_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_db'"
		},
		"ls_adls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adfadvancestgacct.dfs.core.windows.net/"
		},
		"ls_db_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "advanceserversql.database.windows.net"
		},
		"ls_db_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "advancesqldb"
		},
		"ls_db_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pratikadmin"
		},
		"ls_rest_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://pokeapi.co/api/v2/pokemon"
		}
	},
