									"referenceName": "ds_sql",
									"type": "DatasetReference"
								}
							],
							"outputs": [
								{
									"referenceName": "ds_sink",
									"type": "DatasetReference"
								}
							]
						},
						{
							"name": "Max_Cdc",
							"type": "Script",
							"dependsOn": [
